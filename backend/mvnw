#!/bin/sh
# Maven Wrapper script
# https://maven.apache.org/wrapper/

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -r "$MAVEN_WRAPPER_PROPERTIES" ]; then
    MAVEN_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    TMPFILE=$(mktemp /tmp/maven-XXXXXX.zip)
    curl -fsSL -o "$TMPFILE" "$MAVEN_URL"
    unzip -qo "$TMPFILE" -d "$MAVEN_HOME"
    rm -f "$TMPFILE"
fi

MAVEN_EXEC=$(find "$MAVEN_HOME" -name "mvn" -type f -path "*/bin/mvn" | head -1)

if [ -z "$MAVEN_EXEC" ]; then
    echo "Error: Could not find Maven executable" >&2
    exit 1
fi

exec "$MAVEN_EXEC" "$@"
